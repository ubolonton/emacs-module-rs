#!/usr/bin/env bash

# FIX: Use Rust instead of bash to drive the tests.

set -euo pipefail

here=$(cd "$(dirname "$BASH_SOURCE")"; pwd)
source "$here/env.bash"

if [[ $@ == "watch" ]]; then
    (
        cd "$PROJECT_ROOT"
        cargo watch -s bin/build -s bin/test
    )
else
    $EMACS --version

    if [[ $EXT == "dll" ]]; then
        # Diagnostic: show which CRT emacs.exe links against (msvcrt.dll vs ucrtbase.dll).
        # The fd returned by open_channel lives in Emacs's CRT fd table.
        emacs_exe=$(which emacs 2>/dev/null || true)
        if [[ -n $emacs_exe ]]; then
            echo "=== Emacs binary: $emacs_exe ==="
            objdump -p "$emacs_exe" 2>/dev/null | grep "DLL Name" || true
            echo "==================================="
        fi
    fi

    echo "Testing $MODULE_FULL"

    EMACS_MODULE_RS_DEBUG=1 $EMACS -Q -batch --directory "$MODULE_DIR" \
           -l ert \
           -l "$PROJECT_ROOT/test-module/tests/main.el" \
           -f ert-run-tests-batch-and-exit

    echo "Testing test-module-28"

    EMACS_MODULE_RS_DEBUG=1 $EMACS -Q -batch --directory "$MODULE_DIR" \
           -l ert \
           -l "$PROJECT_ROOT/test-module-28/tests/main.el" \
           -f ert-run-tests-batch-and-exit
fi
